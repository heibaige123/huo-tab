{
	"name": "@iconify-json/h-tab-i",
	"description": "h-tab-i icon set in Iconify JSON format",
	"main": "index.js",
	"module": "index.mjs",
	"types": "index.d.ts",
	"exports": {
		"./*": "./*",
		".": {
			"types": "./index.d.ts",
			"require": "./index.js",
			"import": "./index.mjs"
		},
		"./icons.json": "./icons.json"
	},
	"iconSet": {
		"icons": "icons.json"
	},
	"dependencies": {
		"@iconify/types": "*"
	}
}
