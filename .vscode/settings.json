{
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit"
    },
    "files.associations": {
        "*.css": "tailwindcss"
    },
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "css.lint.unknownAtRules": "ignore",
    "css.lint.unknownVendorSpecificProperties": "warning",
    "css.lint.validProperties": ["@apply"],
    "cSpell.words": [
        "breakline",
        "crxjs",
        "duckduckgo",
        "iconify",
        "newtab",
        "Pinia",
        "Prefixs",
        "radash",
        "rushstack",
        "searchbox",
        "sogou",
        "sortablejs",
        "sougou",
        "stylelint",
        "tailwindcss",
        "Unchoose",
        "unref"
    ]
}
